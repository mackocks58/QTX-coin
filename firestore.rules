rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Admin helper ─────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'mackocks588@gmail.com';
    }

    // ── Users collection ────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
    }

    // ── Transactions sub-collection (single-user access) ────────────────
    match /users/{userId}/transactions/{txId} {
      allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
    }

    // ── collectionGroup("transactions") — required for Admin queries ─────
    // This wildcard rule is what allows getDocs(collectionGroup(db, 'transactions'))
    // to succeed. Without it, cross-user collectionGroup reads are always denied.
    match /{path=**}/transactions/{txId} {
      allow read, write: if isAdmin();
    }

    // ── Support Chats ──────────────────────────────────────────────────
    // Admin can read all chats; regular users can only write to their own room
    match /supportChats/{chatId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == chatId);

      // Messages: user can write to own chat, agents/admin can write replies
      match /messages/{msgId} {
        allow read: if request.auth != null;
        allow write: if isAdmin() || (request.auth != null &&
          (request.auth.uid == chatId || request.resource.data.senderRole == 'agent'));
      }
    }

    // ── Deposits collection ────────────────────────────────────────────
    match /deposits/{depositId} {
      allow read, write: if request.auth != null;
    }

    // ── Notifications ──────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read, write: if request.auth != null;
    }

    // ── Deny everything else ───────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
