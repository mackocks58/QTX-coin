rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Support chat images (user uploads their own) ──────────────────
    match /support/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Admin can upload to support/admin/ folder ─────────────────────
    match /support/admin/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // ── Profile images / avatars ──────────────────────────────────────
    match /avatars/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Push notification images (admin) ──────────────────────────────
    match /notifications/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Deposit receipts ──────────────────────────────────────────────
    match /deposits/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // ── Deny everything else ──────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
